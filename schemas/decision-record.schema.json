{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelSwap decision record",
  "type": "object",
  "required": [
    "release_id",
    "route",
    "verdict",
    "incumbent",
    "candidate",
    "sample_window",
    "deltas",
    "dimensions",
    "judge",
    "best_traces",
    "worst_traces",
    "revert_threshold",
    "revert_review_date",
    "rationale"
  ],
  "properties": {
    "release_id": { "type": "string", "minLength": 1 },
    "route": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["swap", "route-split-at-25%", "hold", "defer"] },
    "incumbent": { "type": "string", "minLength": 1 },
    "candidate": { "type": "string", "minLength": 1 },
    "sample_window": {
      "type": "object",
      "required": ["start", "end", "request_count"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" },
        "request_count": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "deltas": {
      "type": "object",
      "required": ["quality", "cost_per_request_usd", "cost_ratio", "latency_p95_ms"],
      "properties": {
        "quality": { "type": "number" },
        "cost_per_request_usd": { "type": "number" },
        "cost_ratio": { "type": "number" },
        "latency_p95_ms": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "judge": {
      "type": "object",
      "required": ["candidate_win_rate", "candidate_wins", "incumbent_wins", "ties"],
      "properties": {
        "candidate_win_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "candidate_wins": { "type": "integer", "minimum": 0 },
        "incumbent_wins": { "type": "integer", "minimum": 0 },
        "ties": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "best_traces": { "$ref": "#/$defs/trace_list" },
    "worst_traces": { "$ref": "#/$defs/trace_list" },
    "revert_threshold": {
      "type": "object",
      "required": [
        "quality_drop_max",
        "cost_increase_max",
        "latency_p95_regression_ms_max"
      ],
      "properties": {
        "quality_drop_max": { "type": "number", "minimum": 0 },
        "cost_increase_max": { "type": "number", "minimum": 0 },
        "latency_p95_regression_ms_max": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "revert_review_date": { "type": "string" },
    "rationale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "trace_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trace_id", "quality_delta", "cost_delta_usd", "latency_delta_ms"],
        "properties": {
          "trace_id": { "type": "string", "minLength": 1 },
          "quality_delta": { "type": "number" },
          "cost_delta_usd": { "type": "number" },
          "latency_delta_ms": { "type": "integer" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

