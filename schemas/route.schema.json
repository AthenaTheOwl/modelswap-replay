{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelSwap route registry",
  "type": "object",
  "required": ["routes"],
  "properties": {
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "incumbent",
          "trace_store",
          "sample",
          "eval_suite",
          "llm_judge_rubric",
          "revert_threshold"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "incumbent": { "type": "string", "minLength": 1 },
          "trace_store": { "type": "string", "minLength": 1 },
          "sample": {
            "type": "object",
            "required": ["window_days", "per_day_n", "strategy", "seed"],
            "properties": {
              "window_days": { "type": "integer", "minimum": 1 },
              "per_day_n": { "type": "integer", "minimum": 1 },
              "strategy": { "enum": ["all", "stratified-by-intent"] },
              "seed": { "type": "integer" }
            },
            "additionalProperties": false
          },
          "eval_suite": { "type": "string", "minLength": 1 },
          "llm_judge_rubric": { "type": "string", "minLength": 1 },
          "revert_threshold": {
            "type": "object",
            "required": [
              "quality_drop_max",
              "cost_increase_max",
              "latency_p95_regression_ms_max"
            ],
            "properties": {
              "quality_drop_max": { "type": "number", "minimum": 0 },
              "cost_increase_max": { "type": "number", "minimum": 0 },
              "latency_p95_regression_ms_max": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

